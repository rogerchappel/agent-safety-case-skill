{
  "name": "agent-safety-case-skill",
  "version": "0.1.0",
  "description": "Draft reviewable safety cases before agent side effects.",
  "type": "module",
  "bin": {
    "agent-safety-case": "./bin/cli.js"
  },
  "scripts": {
    "test": "node --test",
    "check": "node scripts/check.js",
    "lint": "npm run check",
    "smoke": "node bin/cli.js --help && node bin/cli.js fixtures/send-plan.json",
    "package:smoke": "node scripts/verify-package-bin.mjs && npm pack --dry-run",
    "release:check": "npm run lint && npm test && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "agent-skill",
    "agents",
    "cli",
    "dry-run"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "files": [
    "bin",
    "src",
    "fixtures",
    "examples",
    "docs",
    "SKILL.md",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CONTRIBUTING.md",
    "CHANGELOG.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/agent-safety-case-skill.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/agent-safety-case-skill/issues"
  },
  "homepage": "https://github.com/rogerchappel/agent-safety-case-skill#readme",
  "engines": {
    "node": ">=20"
  }
}
